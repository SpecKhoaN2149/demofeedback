# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored and must never be committed.

# Google Gemini API key used by the NLP enrichment pipeline.
# Get one from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-real-key-here

# Optional: override the model (defaults to a built-in priority list).
# GEMINI_MODEL_PRIORITY is a comma-separated list tried in order; the pipeline
# uses the first model that returns insights and falls back on quota/503/504.
GEMINI_MODEL_PRIORITY=gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-2.5-flash
# To force a single model instead, set (this is overridden by the priority list):
# GEMINI_MODEL_NAME=gemini-2.5-flash

# Optional: override the SQLite database path (defaults to submissions.db).
# SUBMISSIONS_DB_PATH=submissions.db
